{
  "expo": {
    "name": "social-auth",
    "slug": "social-auth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "socialauth",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app requires access to your photo library to let you select a profile picture.",
        "NSCameraUsageDescription": "This app requires access to your camera to let you take a profile photo."
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.knlcl.socialauth"
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.knlcl.socialauth"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "edgeToEdgeEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow this app to access your photos to let you choose and upload a profile picture.",
          "cameraPermission": "Allow this app to access your camera so you can take a profile photo directly."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1473f02e-31a1-4881-ae9a-26ba004ea359"
      }
    }
  }
}
